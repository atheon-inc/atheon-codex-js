{
  "name": "@atheon-inc/codex",
  "version": "1.0.0",
  "description": "Javascript SDK for Atheon Analytics Services",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/atheon-inc/atheon-codex-js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "License.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27",
    "typescript": "^6.0.2"
  },
  "versioning": {
    "files": [
      "src/index.ts:__version__"
    ]
  },
  "keywords": [
    "atheon",
    "api",
    "sdk"
  ],
  "author": "Saurabh Ghanekar <saurabh@atheon.ad>",
  "license": "Apache-2.0"
}
